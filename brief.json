    "document_html": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Outil d&#x27;Optimisation des Pratiques d&#x27;Hygiène Alimentaire | Évaluez vos pratiques</title>\n    <meta name=\"description\" content=\"Comparez les recommandations d\">\n    <style>\n        :root {\n            --color-primary: #007bff;\n            --color-secondary: #6c757d;\n            --color-success: #28a745;\n            --color-info: #17a2b8;\n            --color-warning: #ffc107;\n            --color-danger: #dc3545;\n            --color-light: #f8f9fa;\n            --color-dark: #343a40;\n            --color-text: #212529;\n            --color-background: #ffffff;\n            --color-border: #dee2e6;\n            --font-family-sans-serif: \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n            --spacing-unit: 1rem;\n            --border-radius: 0.25rem;\n            --shadow-light: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);\n        }\n\n        body {\n            font-family: var(--font-family-sans-serif);\n            line-height: 1.6;\n            color: var(--color-text);\n            background-color: var(--color-light);\n            margin: 0;\n            padding: 0;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: var(--spacing-unit);\n        }\n\n        header {\n            background-color: var(--color-background);\n            padding: calc(var(--spacing-unit) * 2) 0;\n            border-bottom: 1px solid var(--color-border);\n            text-align: center;\n            box-shadow: var(--shadow-light);\n        }\n\n        header h1 {\n            color: var(--color-dark);\n            margin-top: 0;\n            margin-bottom: var(--spacing-unit);\n            font-size: 2.5rem;\n            letter-spacing: -0.03em;\n        }\n\n        header p {\n            font-size: 1.25rem;\n            color: var(--color-secondary);\n            max-width: 800px;\n            margin: 0 auto;\n        }\n\n        .section {\n            background-color: var(--color-background);\n            padding: calc(var(--spacing-unit) * 2);\n            margin-bottom: var(--spacing-unit);\n            border-radius: var(--border-radius);\n            box-shadow: var(--shadow-light);\n        }\n\n        .section h2 {\n            color: var(--color-dark);\n            font-size: 1.75rem;\n            margin-bottom: var(--spacing-unit);\n            border-bottom: 2px solid var(--color-primary);\n            padding-bottom: 0.5rem;\n        }\n\n        .grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: var(--spacing-unit);\n            margin-top: var(--spacing-unit);\n        }\n\n        .card {\n            background-color: var(--color-light);\n            padding: var(--spacing-unit);\n            border-radius: var(--border-radius);\n            border: 1px solid var(--color-border);\n        }\n\n        label {\n            display: block;\n            margin-bottom: 0.5rem;\n            font-weight: bold;\n            color: var(--color-dark);\n        }\n\n        select, input[type=\"number\"], button {\n            width: 100%;\n            padding: 0.75rem;\n            margin-bottom: var(--spacing-unit);\n            border: 1px solid var(--color-border);\n            border-radius: var(--border-radius);\n            box-sizing: border-box;\n            font-size: 1rem;\n        }\n\n        button {\n            background-color: var(--color-primary);\n            color: white;\n            border: none;\n            cursor: pointer;\n            transition: background-color 0.2s ease;\n        }\n\n        button:hover {\n            background-color: #0056b3;\n        }\n\n        .result-item {\n            background-color: #e9f7ef;\n            border: 1px solid var(--color-success);\n            padding: var(--spacing-unit);\n            margin-bottom: 0.75rem;\n            border-radius: var(--border-radius);\n            color: #1a5a3a;\n        }\n\n        .result-item strong {\n            color: var(--color-dark);\n        }\n\n        .alert {\n            padding: var(--spacing-unit);\n            margin-bottom: var(--spacing-unit);\n            border-radius: var(--border-radius);\n        }\n\n        .alert-info {\n            background-color: var(--color-info);\n            color: white;\n        }\n        .alert-warning {\n            background-color: var(--color-warning);\n            color: var(--color-dark);\n        }\n        .alert-danger {\n            background-color: var(--color-danger);\n            color: white;\n        }\n\n        .seo-section {\n            background-color: var(--color-dark);\n            color: var(--color-light);\n            padding: calc(var(--spacing-unit) * 2);\n            margin-top: calc(var(--spacing-unit) * 2);\n            border-radius: var(--border-radius);\n        }\n        .seo-section h2 {\n            color: white;\n            border-bottom-color: var(--color-secondary);\n        }\n        .seo-section p, .seo-section ul {\n            color: #ced4da;\n        }\n        .seo-section ul {\n            list-style-type: disc;\n            margin-left: var(--spacing-unit);\n            padding-left: 0;\n        }\n        .seo-section li {\n            margin-bottom: 0.5rem;\n        }\n        footer {\n            text-align: center;\n            padding: var(--spacing-unit);\n            margin-top: var(--spacing-unit);\n            color: var(--color-secondary);\n            font-size: 0.9rem;\n        }\n    </style>\n    <meta name=\"robots\" content=\"index, follow\">\n    <link rel=\"canonical\" href=\"https://outil-d-optimisation-des-pratiques-d-hygiene-al-69193c24.onrender.com\">\n    <meta property=\"og:title\" content=\"Outil d&#x27;Optimisation des Pratiques d&#x27;Hygiène Alimentaire\">\n    <meta property=\"og:description\" content=\"Comparez les recommandations d\">\n    <meta property=\"og:url\" content=\"https://outil-d-optimisation-des-pratiques-d-hygiene-al-69193c24.onrender.com\">\n    <meta property=\"og:type\" content=\"website\">\n    <script type=\"application/ld+json\">{\"@context\": \"https://schema.org\", \"@type\": \"WebApplication\", \"name\": \"Outil d'Optimisation des Pratiques d'Hygiène Alimentaire\", \"description\": \"Comparez les recommandations d\", \"url\": \"https://outil-d-optimisation-des-pratiques-d-hygiene-al-69193c24.onrender.com\", \"applicationCategory\": \"UtilityApplication\", \"operatingSystem\": \"Web Browser\"}</script>\n</head>\n<body data-site-slug=\"outil-d-optimisation-des-pratiques-d-hygiene-al-69193c24\" data-runtime-mode=\"analysis_tool\">\n    <header>\n        <div class=\"container\">\n            <h1>Outil d'Optimisation des Pratiques d'Hygiène Alimentaire</h1>\n            <p>Comparez les recommandations d'hygiène pour divers types d'aliments et d'environnements de préparation, et obtenez des conseils pour minimiser les risques. Indispensable pour professionnels et particuliers soucieux de la sécurité alimentaire en France.</p>\n        </div>\n    </header>\n\n    <main class=\"container\">\n        <section class=\"section\">\n            <h2>Évaluez vos pratiques</h2>\n            <p>Utilisez notre simulateur pour obtenir des conseils personnalisés selon vos habitudes de préparation et les aliments concernés.</p>\n            <form id=\"tool-form\">\n                <div class=\"grid\">\n                    <div class=\"card\">\n                        <label for=\"aliment-type\">Type d'aliment principal :</label>\n                        <select id=\"aliment-type\" required>\n                            <option value=\"\">Sélectionnez un type</option>\n                            <option value=\"viande-crue\">Viandes/Volailles Crues</option>\n                            <option value=\"poisson-crue\">Poissons/Fruits de Mer Crus</option>\n                            <option value=\"produits-laitiers\">Produits Laitiers non pasteurisés</option>\n                            <option value=\"legumes-fruits\">Légumes et Fruits frais (non cuits)</option>\n                            <option value=\"plats-prepares\">Plats préparés (à réchauffer)</option>\n                            <option value=\"patisseries-sensibles\">Pâtisseries à crème/œufs crus</option>\n                        </select>\n                    </div>\n                    <div class=\"card\">\n                        <label for=\"environnement\">Environnement de préparation :</label>\n                        <select id=\"environnement\" required>\n                            <option value=\"\">Sélectionnez un environnement</option>\n                            <option value=\"domicile\">Cuisine domestique</option>\n                            <option value=\"restauration-petite\">Petite restauration/Traiteur</option>\n                            <option value=\"restauration-grande\">Grande cuisine/Restaurant étoilé</option>\n                            <option value=\"marche-plein-air\">Marché en plein air/Vente ambulante</option>\n                        </select>\n                    </div>\n                    <div class=\"card\">\n                        <label for=\"temperature-stockage\">Température moyenne de stockage (°C) :</label>\n                        <input type=\"number\" id=\"temperature-stockage\" value=\"4\" min=\"-20\" max=\"30\" required>\n                    </div>\n                    <div class=\"card\">\n                        <label for=\"temps-conservation\">Temps de conservation (heures) avant consommation/préparation :</label>\n                        <input type=\"number\" id=\"temps-conservation\" value=\"24\" min=\"0\" max=\"168\" required>\n                    </div>\n                </div>\n                <button type=\"submit\" id=\"tool-submit\" data-affiliate-slot=\"hygiene-audit\">Obtenir des Conseils Personnalisés</button>\n            </form>\n        </section>\n\n        <section class=\"section\">\n            <h2>Vos Recommandations Personnalisées</h2>\n            <div id=\"tool-result\">\n                <div class=\"alert alert-info\">Veuillez remplir le formulaire ci-dessus pour obtenir vos conseils d'hygiène personnalisés.</div>\n            </div>\n        </section>\n\n        <section class=\"section\">\n            <h2>Principes Clés de Sécurité Alimentaire</h2>\n            <div class=\"grid\">\n                <div class=\"card\">\n                    <h3>1. Nettoyage</h3>\n                    <p>Lavez-vous les mains fréquemment, nettoyez et désinfectez toutes les surfaces, ustensiles et équipements. L'eau potable est essentielle.</p>\n                </div>\n                <div class=\"card\">\n                    <h3>2. Séparation</h3>\n                    <p>Séparez les aliments crus des aliments cuits pour éviter la contamination croisée. Utilisez des planches et ustensiles différents.</p>\n                </div>\n                <div class=\"card\">\n                    <h3>3. Cuisson</h3>\n                    <p>Faites cuire les aliments à des températures adéquates. Utilisez un thermomètre pour vérifier les températures internes, notamment pour les viandes.</p>\n                </div>\n                <div class=\"card\">\n                    <h3>4. Refroidissement</h3>\n                    <p>Réfrigérez ou congelez rapidement les aliments périssables. Ne laissez pas les aliments cuits à température ambiante trop longtemps.</p>\n                </div>\n            </div>\n        </section>\n\n        <section class=\"section\">\n            <h2>Témoignages & Confiance</h2>\n            <div class=\"grid\">\n                <div class=\"card\">\n                    <p>\"En tant que gérant de brasserie à Lyon, cet outil m'a permis de mieux former mon équipe et d'anticiper les contrôles sanitaires. Très utile !\"</p>\n                    <small>— Marc D., Restaurateur</small>\n                </div>\n                <div class=\"card\">\n                    <p>\"Je suis diététicienne et je recommande souvent cet outil à mes patients pour qu'ils adoptent de meilleures pratiques à la maison. Clair et efficace.\"</p>\n                    <small>— Sophie L., Diététicienne</small>\n                </div>\n            </div>\n        </section>\n    </main>\n\n    <div class=\"seo-section\">\n        <div class=\"container\">\n            <h2>Hygiène Alimentaire France : Guide Complet et Outils</h2>\n            <p>La sécurité alimentaire est une priorité en France, que vous soyez un professionnel de la restauration, un traiteur ou un particulier soucieux de la santé de votre famille. Notre outil interactif vous aide à naviguer dans les réglementations et les bonnes pratiques pour une cuisine irréprochable.</p>\n            <h3>Pourquoi l'hygiène en cuisine est-elle cruciale ?</h3>\n            <ul>\n                <li><strong>Prévention des Intoxications Alimentaires :</strong> Chaque année, des milliers de cas sont recensés. Une bonne hygiène est votre première ligne de défense.</li>\n                <li><strong>Conformité Réglementaire :</strong> Pour les professionnels (restaurants, cantines, food trucks), respecter les normes HACCP et les directives de la DGCCRF est impératif pour éviter amendes et fermetures.</li>\n                <li><strong>Qualité et Goût :</strong> Une manipulation saine des aliments préserve leurs qualités organoleptiques et prolonge leur durée de vie.</li>\n                <li><strong>Confiance des Consommateurs :</strong> Une réputation d'excellence en hygiène est un atout majeur, surtout dans le secteur alimentaire.</li>\n            </ul>\n            <h3>Comment notre plateforme vous accompagne ?</h3>\n            <p>Notre simulateur compare vos pratiques actuelles aux standards recommandés pour différents types d'aliments (viandes crues, poissons, légumes, produits laitiers) et d'environnements de préparation (domicile, restaurant, marché). Vous recevez des conseils précis sur :</p>\n            <ul>\n                <li>Le contrôle des températures de stockage et de cuisson.</li>\n                <li>La prévention de la contamination croisée.</li>\n                <li>Les délais de conservation optimaux.</li>\n                <li>Les méthodes de nettoyage et de désinfection adaptées.</li>\n            </ul>\n            <p>Que vous recherchiez des informations sur les <strong>normes d'hygiène en restauration</strong>, des <strong>conseils de sécurité alimentaire à domicile</strong>, ou un <strong>guide des bonnes pratiques HACCP simplifié</strong>, cet outil est conçu pour vous. Améliorez votre sécurité alimentaire dès aujourd'hui !</p>\n        </div>\n    </div>\n\n    <footer>\n        <div class=\"container\">\n            <p>&copy; 2023 Sécurité Alimentaire France. Tous droits réservés.</p>\n        </div>\n    </footer>\n\n    <script>\n        document.getElementById('tool-form').addEventListener('submit', function(e) {\n            e.preventDefault();\n\n            const alimentType = document.getElementById('aliment-type').value;\n            const environnement = document.getElementById('environnement').value;\n            const temperatureStockage = parseInt(document.getElementById('temperature-stockage').value);\n            const tempsConservation = parseInt(document.getElementById('temps-conservation').value);\n            const resultDiv = document.getElementById('tool-result');\n            resultDiv.innerHTML = ''; // Clear previous results\n\n            let conseils = [];\n            let risques = [];\n\n            // General advice\n            conseils.push(\"<strong>Lavage des mains :</strong> Toujours se laver les mains avant et après avoir manipulé des aliments, surtout après des produits crus.\");\n            conseils.push(\"<strong>Nettoyage des surfaces :</strong> Nettoyez et désinfectez systématiquement les surfaces de travail et les ustensiles.\");\n\n            // Aliment specific\n            if (alimentType === 'viande-crue' || alimentType === 'poisson-crue') {\n                conseils.push(\"<strong>Séparation des crus :</strong> Utilisez une planche à découper et des ustensiles distincts pour les viandes/poissons crus. Ne jamais laisser entrer en contact avec les aliments cuits ou prêts à consommer.\");\n                conseils.push(\"<strong>Cuisson à cœur :</strong> Assurez une cuisson complète (températures internes spécifiques) pour éliminer les bactéries.\");\n                risques.push(\"Risque élevé de contamination bactérienne (Salmonella, E. coli, Listeria).\");\n            } else if (alimentType === 'produits-laitiers') {\n                conseils.push(\"<strong>Chaîne du froid :</strong> Maintenez rigoureusement la chaîne du froid. Les produits non pasteurisés sont plus sensibles.\");\n                risques.push(\"Risque de Listeria ou d'autres pathogènes si la chaîne du froid est brisée ou le produit périmé.\");\n            } else if (alimentType === 'legumes-fruits') {\n                conseils.push(\"<strong>Lavage minutieux :</strong> Lavez abondamment les légumes et fruits frais à l'eau potable avant consommation, même ceux à éplucher.\");\n                risques.push(\"Risque de résidus de pesticides ou de contamination par la terre si mal lavés.\");\n            } else if (alimentType === 'plats-prepares') {\n                conseils.push(\"<strong>Réchauffage complet :</strong> Réchauffez les plats préparés à une température d'au moins 70°C à cœur. Ne pas réchauffer plus d'une fois.\");\n                risques.push(\"Risque de développement bactérien si réchauffage insuffisant ou stockage prolongé.\");\n            } else if (alimentType === 'patisseries-sensibles') {\n                conseils.push(\"<strong>Température et temps :</strong> Ces produits sont très sensibles. Consommez rapidement et stockez au frais. Évitez les œufs crus pour les personnes sensibles.\");\n                risques.push(\"Risque de Salmonellose élevé si les œufs sont contaminés ou la conservation inadéquate.\");\n            }\n\n            // Environment specific\n            if (environnement === 'restauration-petite' || environnement === 'restauration-grande') {\n                conseils.push(\"<strong>Plan HACCP :</strong> Un plan HACCP doit être en place et suivi scrupuleusement. Formation du personnel essentielle.\");\n                conseils.push(\"<strong>Traçabilité :</strong> Assurez une traçabilité complète des produits.\");\n                risques.push(\"Conséquences réglementaires et réputationnelles en cas de manquement.\");\n            } else if (environnement === 'marche-plein-air') {\n                conseils.push(\"<strong>Protection :</strong> Protégez les aliments des intempéries, de la poussière et des insectes. Maintenez les températures requises par des moyens adaptés (glacières, vitrines réfrigérées).\");\n                risques.push(\"Risque de contamination environnementale et de rupture de la chaîne du froid.\");\n            }\n\n            // Temperature and time specific\n            if (temperatureStockage > 5) {\n                risques.push(`La température de stockage de ${temperatureStockage}°C est trop élevée pour la plupart des aliments périssables. Cela favorise la croissance bactérienne.`);\n                conseils.push(\"<strong>Température critique :</strong> Maintenez les réfrigérateurs à 0-4°C pour la majorité des produits frais.\");\n            } else if (temperatureStockage < 0 && alimentType !== 'viande-crue' && alimentType !== 'poisson-crue') {\n                conseils.push(\"<strong>Congélation :</strong> Une température négative est pour la congélation, assurez un emballage adapté pour éviter le gel et la perte de qualité.\");\n            }\n\n            if (tempsConservation > 48 && (alimentType === 'viande-crue' || alimentType === 'poisson-crue' || alimentType === 'produits-laitiers' || alimentType === 'patisseries-sensibles')) {\n                risques.push(`Un temps de conservation de ${tempsConservation} heures pour ce type d'aliment est potentiellement trop long, même au frais.`);\n                conseils.push(\"<strong>Date limite :</strong> Respectez scrupuleusement les dates limites de consommation (DLC) et utilisez le principe du 'premier entré, premier sorti'.\");\n            } else if (tempsConservation > 72 && (alimentType === 'legumes-fruits' || alimentType === 'plats-prepares')) {\n                 risques.push(`Un temps de conservation de ${tempsConservation} heures pour ce type d'aliment est potentiellement trop long, même au frais.`);\n                 conseils.push(\"<strong>Qualité :</strong> Au-delà de 3 jours, la qualité et la fraîcheur peuvent être altérées, même si le produit est encore comestible.\");\n            }\n\n            if (risques.length > 0) {\n                resultDiv.innerHTML += '<div class=\"alert alert-warning\"><strong>Attention :</strong> Des risques potentiels ont été identifiés pour vos pratiques.</div>';\n                risques.forEach(r => {\n                    resultDiv.innerHTML += `<div class=\"result-item\">⚠️ ${r}</div>`;\n                });\n            } else {\n                resultDiv.innerHTML += '<div class=\"alert alert-success\"><strong>Félicitations :</strong> Vos pratiques semblent être sur la bonne voie, mais une vigilance constante reste de mise !</div>';\n            }\n            \n            conseils.forEach(c => {\n                resultDiv.innerHTML += `<div class=\"result-item\">${c}</div>`;\n            });\n            \n            resultDiv.innerHTML += '<div class=\"alert alert-info\">Ces conseils sont des recommandations générales. Pour des situations spécifiques, consultez les réglementations sanitaires en vigueur.</div>';\n        });\n    </script>\n<div id=\"qa-smoke-result\" hidden></div>\n<script id=\"farmbuilder-affiliate-helper\">\n(function () {\n  window.__UTILITY_AFFILIATE_MAP = window.__UTILITY_AFFILIATE_MAP || {};\n  document.addEventListener(\"click\", function (event) {\n    const target = event.target.closest(\"[data-affiliate-slot]\");\n    if (!target) return;\n    const slot = target.getAttribute(\"data-affiliate-slot\");\n    const href = window.__UTILITY_AFFILIATE_MAP[slot];\n    if (!href) return;\n    if (target.tagName && target.tagName.toLowerCase() === \"a\") {\n      target.setAttribute(\"href\", href);\n      target.setAttribute(\"rel\", \"nofollow sponsored noopener noreferrer\");\n      return;\n    }\n    event.preventDefault();\n    window.open(href, \"_blank\", \"noopener\");\n  }, true);\n})();\n</script>\n<script id=\"farmbuilder-functional-qa\">\n(function () {\n  function marker() {\n    let node = document.getElementById(\"qa-smoke-result\");\n    if (node) return node;\n    node = document.createElement(\"div\");\n    node.id = \"qa-smoke-result\";\n    node.hidden = true;\n    document.body.appendChild(node);\n    return node;\n  }\n\n  let qaFinished = false;\n  let qaWatchdog = null;\n\n  function normalize(text) {\n    return String(text || \"\").replace(/\\s+/g, \" \").trim();\n  }\n\n  function findForm() {\n    return document.getElementById(\"tool-form\") || document.querySelector(\"form\");\n  }\n\n  function findResult() {\n    return (\n      document.getElementById(\"tool-result\") ||\n      document.querySelector(\"[data-result]\") ||\n      document.querySelector(\".tool-result, .result-card, .result, .results, .output, .preview, .diagnostic, .analysis\")\n    );\n  }\n\n  function primaryAction(form) {\n    if (!form) return null;\n    return (\n      document.getElementById(\"tool-submit\") ||\n      form.querySelector(\"#tool-submit\") ||\n      form.querySelector(\"[data-primary-action]\") ||\n      form.querySelector(\"button[type=submit]\") ||\n      form.querySelector(\"button\") ||\n      form.querySelector(\"input[type=submit]\")\n    );\n  }\n\n  function resultSignature(node) {\n    if (!node) return \"\";\n    const text = normalize(node.textContent);\n    const html = normalize(node.innerHTML).slice(0, 600);\n    return `${text}||${html}`;\n  }\n\n  function resultHeadline(node) {\n    if (!node) return \"\";\n    const heading = node.querySelector(\"h1, h2, h3, strong, b\");\n    return normalize(heading ? heading.textContent : \"\");\n  }\n\n  function sampleText(field) {\n    const key = `${field.id || \"\"} ${field.name || \"\"} ${field.placeholder || \"\"}`.toLowerCase();\n    if (/email/.test(key)) return \"bonjour@example.com\";\n    if (/url|site|website|lien/.test(key)) return \"https://example.com/offre-solaire\";\n    if (/phone|tel|mobile/.test(key)) return \"0612345678\";\n    if (/ville|city|localisation|location|region|departement|postal/.test(key)) return \"Paris\";\n    if (/orientation/.test(key)) return \"sud\";\n    if (/keyword|theme|topic|sujet|subject/.test(key)) return \"energie solaire domestique\";\n    if (/titre|title/.test(key)) return \"Simulateur solaire maison\";\n    if (/nom|name|project/.test(key)) return \"Projet Horizon\";\n    if (/description|notes|content|message/.test(key)) return \"Maison individuelle exposee sud avec toiture exploitable.\";\n    return field.placeholder || \"France\";\n  }\n\n  function sampleNumber(field) {\n    const key = `${field.id || \"\"} ${field.name || \"\"}`.toLowerCase();\n    if (/inclinaison|angle|slope/.test(key)) return \"30\";\n    if (/surface|size|m2|sqm/.test(key)) return \"28\";\n    if (/annee|year/.test(key)) return \"2024\";\n    if (/prix|price|budget|cost|amount|montant/.test(key)) return \"12000\";\n    const min = Number(field.min || \"\");\n    const max = Number(field.max || \"\");\n    if (Number.isFinite(min) && Number.isFinite(max) && max >= min) {\n      return String(Math.min(max, Math.max(min, min + Math.round((max - min) * 0.35))));\n    }\n    if (Number.isFinite(min)) return String(Math.max(min, 12));\n    if (Number.isFinite(max)) return String(Math.min(max, 12));\n    return field.value || \"12\";\n  }\n\n  function applySample(field) {\n    const tag = (field.tagName || \"\").toLowerCase();\n    const type = (field.type || \"\").toLowerCase();\n    if (field.disabled) return;\n    if (type === \"hidden\" || type === \"submit\" || type === \"button\" || type === \"reset\" || type === \"image\" || type === \"file\") {\n      return;\n    }\n    const currentValue = normalize(field.value);\n    if (tag === \"select\") {\n      if (currentValue) return;\n      const option = Array.from(field.options || []).find((item) => item.value && !item.disabled) || field.options[0];\n      if (option) field.value = option.value;\n      return;\n    }\n    if (type === \"checkbox\") {\n      if (field.checked) return;\n      field.checked = true;\n      return;\n    }\n    if (type === \"radio\") {\n      if (field.checked) return;\n      field.checked = true;\n      return;\n    }\n    if (type === \"date\") {\n      if (currentValue) return;\n      field.value = \"2026-03-01\";\n      return;\n    }\n    if (type === \"email\") {\n      if (currentValue) return;\n      field.value = \"bonjour@example.com\";\n      return;\n    }\n    if (type === \"url\") {\n      if (currentValue) return;\n      field.value = \"https://example.com/offre-solaire\";\n      return;\n    }\n    if (type === \"tel\") {\n      if (currentValue) return;\n      field.value = \"0612345678\";\n      return;\n    }\n    if (type === \"color\") {\n      if (currentValue) return;\n      field.value = \"#2f855a\";\n      return;\n    }\n    if (type === \"number\" || type === \"range\") {\n      if (currentValue) return;\n      field.value = sampleNumber(field);\n      return;\n    }\n    if (currentValue) return;\n    field.value = sampleText(field);\n  }\n\n  function stamp(status, detail, headline, primary) {\n    if (qaFinished) return;\n    qaFinished = true;\n    if (qaWatchdog) {\n      window.clearTimeout(qaWatchdog);\n      qaWatchdog = null;\n    }\n    const node = marker();\n    node.dataset.status = status;\n    node.dataset.mode = \"native-form\";\n    node.dataset.detail = detail || \"\";\n    node.dataset.headline = headline || \"\";\n    node.dataset.primary = primary || \"\";\n    node.dataset.viewport = window.innerWidth <= 640 ? \"mobile\" : \"desktop\";\n    window.setTimeout(function () {\n      try {\n        window.stop();\n      } catch (_error) {}\n    }, 0);\n  }\n\n  function installModalGuards() {\n    const noop = function () {};\n    const approve = function () { return true; };\n    const empty = function () { return \"\"; };\n    try { window.alert = noop; } catch (_error) {}\n    try { window.confirm = approve; } catch (_error) {}\n    try { window.prompt = empty; } catch (_error) {}\n  }\n\n  function triggerAction(form, action) {\n    try {\n      if (typeof form.requestSubmit === \"function\") {\n        form.requestSubmit(action || undefined);\n        return;\n      }\n    } catch (_error) {}\n    if (action && typeof action.click === \"function\") {\n      action.click();\n      return;\n    }\n    form.dispatchEvent(new Event(\"submit\", { bubbles: true, cancelable: true }));\n  }\n\n  function inspectResult(before, attemptsLeft) {\n    const result = findResult();\n    if (!result) {\n      stamp(\"fail\", \"La zone de resultat est introuvable.\", \"\");\n      return;\n    }\n    const after = resultSignature(result);\n    const text = normalize(result.textContent);\n    if (after && after !== before && text.length >= 24) {\n      const primary = result.querySelector(\"a[href], button[data-href], [data-primary-url]\") || document.querySelector(\"#tool-result a[href]\");\n      stamp(\"pass\", \"Le formulaire natif a mis a jour la zone de resultat.\", resultHeadline(result), primary ? (primary.getAttribute(\"href\") || primary.getAttribute(\"data-primary-url\") || \"\") : \"\");\n      return;\n    }\n    if (attemptsLeft > 0) {\n      window.setTimeout(function () {\n        inspectResult(before, attemptsLeft - 1);\n      }, 250);\n      return;\n    }\n    stamp(\"fail\", \"La zone de resultat n'a pas renvoye de contenu exploitable.\", resultHeadline(result));\n  }\n\n  function runSmoke() {\n    const params = new URLSearchParams(window.location.search);\n    if (params.get(\"__qa\") !== \"functional\") return;\n    qaWatchdog = window.setTimeout(function () {\n      stamp(\"fail\", \"QA smoke timed out before the page reported a usable result.\", \"\");\n    }, 7000);\n    const form = findForm();\n    if (!form) {\n      stamp(\"fail\", \"Le formulaire principal est introuvable.\", \"\");\n      return;\n    }\n    const result = findResult();\n    const before = resultSignature(result);\n    installModalGuards();\n    try {\n      form.querySelectorAll(\"input, select, textarea\").forEach(applySample);\n    } catch (error) {\n      stamp(\"fail\", error && error.message ? `QA smoke sample failed: ${error.message}` : \"QA smoke sample failed before submit.\", \"\");\n      return;\n    }\n    const action = primaryAction(form);\n    try {\n      triggerAction(form, action);\n    } catch (error) {\n      stamp(\"fail\", error && error.message ? `QA smoke submit failed: ${error.message}` : \"QA smoke submit failed.\", \"\");\n      return;\n    }\n    inspectResult(before, 10);\n  }\n\n  window.addEventListener(\"error\", function (event) {\n    const message = event && event.message ? event.message : \"JavaScript runtime error during QA smoke.\";\n    stamp(\"fail\", `QA smoke JS error: ${message}`, \"\");\n  }, { once: true });\n\n  window.addEventListener(\"unhandledrejection\", function (event) {\n    const reason = event && event.reason;\n    const detail = typeof reason === \"string\"\n      ? reason\n      : reason && reason.message\n        ? reason.message\n        : \"Unhandled promise rejection during QA smoke.\";\n    stamp(\"fail\", `QA smoke rejection: ${detail}`, \"\");\n  }, { once: true });\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", function () {\n      window.setTimeout(runSmoke, 60);\n    }, { once: true });\n  } else {\n    window.setTimeout(runSmoke, 60);\n  }\n})();\n</script>\n</body>\n</html>",
